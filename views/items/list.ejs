<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Items</title>
  </head>
  <body>
    <div>
      <ul>
        <% items.forEach(item => { %>
        <li style="margin-bottom: 15px">
          <strong><%= item.year %> <%= item.brand %> <%= item.name %></strong> -
          $<%= item.price %><br />
          <%= item.description %><br />
          <a href="/items/<%= item.id %>">View</a> |
          <a href="/items/<%= item.id %>/update">Edit</a> |
          <form
            method="POST"
            action="/items/<%= item.id %>/delete"
            style="display: inline"
          >
            <button type="submit" onclick="return confirm('Delete this item?')">
              Delete
            </button>
          </form>
        </li>
        <% }); %>
      </ul>

      <a href="/items/new">Add New Motorcycle</a> |
      <a href="/">Return Home</a>
    </div>
  </body>
</html>
