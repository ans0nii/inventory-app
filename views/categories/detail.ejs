<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Categories Detail</title>
  </head>
  <body>
    <h1><%= category.name %></h1>
    <p><%= category.description %></p>
    <hr />
    <a href="/categories/<%= category.id %>/update">Edit Category</a> |
    <form
      method="POST"
      action="/categories/<%= category.id %>/delete"
      style="display: inline"
    >
      <button type="submit" onclick="return confirm('Delete this category?')">
        Delete
      </button>
    </form>
    <br /><br />
    <a href="/categories">Back to Categories</a>
  </body>
</html>
