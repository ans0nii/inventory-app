<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Categories</title>
  </head>
  <body>
    <div>
      <ul>
        <% categories.forEach(category => { %>
        <li style="margin-bottom: 15px">
          <strong><%= category.name %></strong> - <%= category.description %><br />
          <a href="/categories/<%= category.id %>">View</a> |
          <a href="/categories/<%= category.id %>/update">Edit</a> |
          <form
            method="POST"
            action="/categories/<%= category.id %>/delete"
            style="display: inline"
          >
            <button
              type="submit"
              onclick="return confirm('Delete this category?')"
            >
              Delete
            </button>
          </form>
        </li>
        <% }); %>
      </ul>

      <a href="/categories/new">Add New Category</a> |
      <a href="/">Return Home</a>
    </div>
  </body>
</html>
